---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="container">
		<nav class="main-nav" aria-label="Main navigation">
			<a href="/" class="logo">
				<svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="11" cy="4" r="2"></circle>
					<circle cx="18" cy="8" r="2"></circle>
					<circle cx="20" cy="16" r="2"></circle>
					<path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"></path>
				</svg>
				<span class="logo-text">{SITE_TITLE}</span>
			</a>

			<button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false" id="menu-toggle">
				<span></span>
				<span></span>
				<span></span>
			</button>

			<div class="nav-links" id="nav-links">
				<HeaderLink href="/categories/best-picks/">Best Picks</HeaderLink>
				<HeaderLink href="/categories/pet-knowledge/">Pet Knowledge</HeaderLink>
				<HeaderLink href="/categories/problem-solving/">Problem Solving</HeaderLink>
				<HeaderLink href="/categories/care-guides/">Care Guides</HeaderLink>
				<HeaderLink href="/about/">About</HeaderLink>
				<HeaderLink href="/newsletter/" class="btn btn-primary nav-cta">Newsletter</HeaderLink>
			</div>
		</nav>
	</div>
</header>

<script>
	const menuToggle = document.getElementById('menu-toggle');
	const navLinks = document.getElementById('nav-links');

	if (menuToggle && navLinks) {
		menuToggle.addEventListener('click', () => {
			const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
			menuToggle.setAttribute('aria-expanded', String(!isExpanded));
			navLinks.classList.toggle('is-open');
		});
	}
</script>

<style>
	.site-header {
		background-color: rgba(253, 251, 247, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid hsl(var(--border));
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.main-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		gap: var(--spacing-lg);
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
	}

	.logo:hover {
		text-decoration: none;
		opacity: 0.85;
	}

	.logo-icon {
		width: 2rem;
		height: 2rem;
		color: hsl(var(--primary));
		flex-shrink: 0;
	}

	.logo-text {
		font-family: var(--font-heading);
		font-size: 1.45rem;
		font-weight: 700;
		color: hsl(var(--foreground));
		white-space: nowrap;
		line-height: 1;
		letter-spacing: -0.01em;
	}

	@media (max-width: 768px) {
		.logo-icon {
			width: 1.75rem;
			height: 1.75rem;
		}

		.logo-text {
			font-size: 1.25rem;
		}
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.nav-links :global(a) {
		padding: 0.625rem 0.875rem;
		border-radius: var(--radius-md);
		color: rgba(45, 45, 45, 0.7);
		font-size: 1rem;
		font-weight: 500;
		transition: color 0.2s ease, background-color 0.2s ease;
	}

	.nav-links :global(a:hover) {
		color: hsl(var(--primary));
		background-color: hsl(var(--primary) / 0.05);
		text-decoration: none;
	}

	.nav-links :global(a.active) {
		color: hsl(var(--primary));
		background-color: hsl(var(--primary) / 0.05);
		font-weight: 600;
		text-decoration: none;
	}

	.nav-links :global(.nav-cta) {
		margin-left: 0.75rem;
		padding: 0.625rem 1.25rem;
		font-size: 1rem;
		border-radius: var(--radius-button);
		color: hsl(var(--primary-foreground));
		background-color: hsl(var(--primary));
	}

	.nav-links :global(.nav-cta:hover) {
		background-color: hsl(var(--primary-dark));
		color: hsl(var(--primary-foreground));
	}

	.nav-links :global(.nav-cta:active) {
		background-color: hsl(17 54% 40%);
		color: hsl(var(--primary-foreground));
	}

	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: var(--spacing-sm);
	}

	.mobile-menu-toggle span {
		display: block;
		width: 24px;
		height: 2px;
		background-color: hsl(var(--foreground));
		transition: transform 0.2s ease;
	}

	@media (max-width: 768px) {
		.mobile-menu-toggle {
			display: flex;
		}

		.nav-links {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background-color: hsl(var(--card));
			flex-direction: column;
			padding: var(--spacing-md);
			box-shadow: var(--shadow-lg);
			gap: 0;
			border-bottom: 1px solid hsl(var(--border));
		}

		.nav-links.is-open {
			display: flex;
		}

		.nav-links :global(a) {
			width: 100%;
			padding: var(--spacing-md);
			border-bottom: 1px solid hsl(var(--border));
			border-radius: 0;
		}

		.nav-links :global(.nav-cta) {
			margin-left: 0;
			margin-top: var(--spacing-sm);
			width: 100%;
			text-align: center;
		}
	}
</style>
