---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf()
);

const latestPosts = posts.slice(0, 3);

const categories = [
	{
		slug: 'best-picks',
		title: 'Best Picks',
		description: 'Top-rated feeding products, tested and compared.',
		icon: 'bowl',
	},
	{
		slug: 'pet-knowledge',
		title: 'Pet Knowledge',
		description: 'Understand your pet\'s eating behavior and health needs.',
		icon: 'book',
	},
	{
		slug: 'problem-solving',
		title: 'Problem Solving',
		description: 'Practical answers to common feeding challenges.',
		icon: 'puzzle',
	},
	{
		slug: 'care-guides',
		title: 'Care Guides',
		description: 'Step-by-step routines for healthier mealtime habits.',
		icon: 'heart',
	},
];

const trustItems = [
	{ icon: 'chart', title: 'Data-Driven', description: 'We analyze thousands of reviews' },
	{ icon: 'shield', title: 'Vet-Reviewed', description: 'Health content checked by experts' },
	{ icon: 'paw', title: 'Pet-First', description: 'Recommendations prioritize safety' },
	{ icon: 'scale', title: 'Unbiased', description: 'We earn from affiliates, not brands' },
];
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero section-lg">
				<div class="container hero-grid">
					<div class="hero-content">
						<span class="hero-eyebrow">Research-backed pet feeding guides</span>
						<h1>Smarter Feeding Decisions for <span class="text-accent">Healthier Pets</span></h1>
						<p class="hero-subtitle">
							Honest product reviews and practical guides to help you choose the best food, bowls, and feeding routines for your furry family.
						</p>
						<div class="hero-cta">
							<a href="/blog/" class="btn btn-primary btn-lg">Explore Guides</a>
							<a href="/about/" class="btn btn-secondary btn-lg">How We Research</a>
						</div>
						<div class="hero-newsletter">
							<NewsletterForm
								title=""
								description="Join thousands of thoughtful pet owners. Get our free Dog Feeding Safety Checklist."
								buttonText="Get Free Checklist"
								compact={true}
							/>
						</div>
					</div>
					<div class="hero-image">
						<img src="/images/hero.jpg" alt="Golden retriever eating from a bowl in a sunny kitchen" />
					</div>
				</div>
			</section>

			<!-- Trust Bar -->
			<section class="trust-bar section-sm bg-surface">
				<div class="container">
					<div class="trust-grid">
						{trustItems.map((item) => (
							<div class="trust-item">
								<div class={`trust-icon trust-icon-${item.icon}`} aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										{item.icon === 'chart' && (
											<>
												<path d="M3 3v18h18" />
												<path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3" />
											</>
										)}
										{item.icon === 'shield' && (
											<>
												<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
												<path d="M9 12l2 2 4-4" />
											</>
										)}
										{item.icon === 'paw' && (
											<>
												<circle cx="12" cy="9" r="3" />
												<circle cx="6" cy="15" r="2" />
												<circle cx="18" cy="15" r="2" />
												<path d="M12 12c-3 0-5 2-5 5h10c0-3-2-5-5-5z" />
											</>
										)}
										{item.icon === 'scale' && (
											<>
												<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z" />
												<path d="M12 6v6l4 2" />
											</>
										)}
									</svg>
								</div>
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Categories -->
			<section class="categories section">
				<div class="container">
					<div class="section-header text-center">
						<span class="section-eyebrow">Browse by Topic</span>
						<h2>Explore Our Guides</h2>
						<p class="text-muted section-lead">Everything you need to make informed feeding decisions.</p>
					</div>
					<div class="category-grid">
						{categories.map((cat) => (
							<a href={`/categories/${cat.slug}/`} class="category-card">
								<div class={`category-icon category-icon-${cat.icon}`} aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										{cat.icon === 'bowl' && (
											<>
												<path d="M4 10c0-4 3.6-6 8-6s8 2 8 6" />
												<path d="M4 10v2a8 8 0 0 0 16 0v-2" />
												<path d="M12 18v3" />
											</>
										)}
										{cat.icon === 'book' && (
											<>
												<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
												<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
											</>
										)}
										{cat.icon === 'puzzle' && (
											<>
												<path d="M19 11h-4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v6z" />
												<path d="M13 5h-2a2 2 0 0 0-2 2v2a2 2 0 0 1-2 2H5a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h6" />
												<path d="M19 13v6a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2v-2a2 2 0 0 0-2-2H5" />
											</>
										)}
										{cat.icon === 'heart' && (
											<>
												<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
											</>
										)}
									</svg>
								</div>
								<h3>{cat.title}</h3>
								<p class="text-muted">{cat.description}</p>
								<span class="category-link">Browse guides →</span>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- Latest Articles -->
			<section class="latest-articles section bg-surface">
				<div class="container">
					<div class="section-header">
						<div>
							<span class="section-eyebrow">Fresh from the blog</span>
							<h2>Latest Articles</h2>
						</div>
						<a href="/blog/" class="view-all">View all articles →</a>
					</div>
					<div class="article-grid">
						{latestPosts.map((post) => (
							<article class="article-card">
								<a href={`/blog/${post.id}/`} class="article-card-link">
									<div class="article-image">
										<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
									</div>
									<div class="article-card-content">
										{post.data.categories && post.data.categories[0] && (
											<span class="badge badge-secondary article-category">
												{post.data.categories[0].replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase())}
											</span>
										)}
										<h3>{post.data.title}</h3>
										<p class="text-muted">{post.data.description}</p>
										<span class="read-more">Read More →</span>
									</div>
								</a>
							</article>
						))}
					</div>
				</div>
			</section>

			<!-- Research Process -->
			<section class="research-process section">
				<div class="container research-grid">
					<div class="research-image">
						<img src="/images/about.jpg" alt="Beagle waiting patiently by a feeding bowl" />
					</div>
					<div class="research-content">
						<span class="section-eyebrow">Our Process</span>
						<h2>How We Choose What to Recommend</h2>
						<p class="text-muted research-intro">
							Every guide starts with real data and ends with advice we would follow for our own pets.
						</p>
						<ol class="research-steps">
							<li>Analyze verified reviews from Amazon, Chewy, and Reddit</li>
							<li>Compare product specs, materials, and safety standards</li>
							<li>Consult veterinary sources and feeding research</li>
							<li>Test products hands-on when possible</li>
							<li>Update guides regularly as new products launch</li>
						</ol>
						<a href="/about/" class="btn btn-secondary">Learn More About Us</a>
					</div>
				</div>
			</section>

			<!-- Newsletter CTA -->
			<section class="newsletter-cta section bg-primary-soft">
				<div class="container-narrow text-center">
					<span class="section-eyebrow">Stay informed</span>
					<h2>Get weekly pet feeding tips in your inbox</h2>
					<p class="text-muted">No spam. Just practical advice, honest reviews, and money-saving finds.</p>
					<NewsletterForm buttonText="Subscribe" />
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero */
	.hero {
		padding: var(--spacing-4xl) 0;
		background: linear-gradient(135deg, hsl(var(--background)) 0%, hsl(var(--primary) / 0.05) 100%);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-3xl);
		align-items: center;
	}

	.hero-eyebrow {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: hsl(var(--primary));
		margin-bottom: var(--spacing-sm);
	}

	.hero-content h1 {
		margin-bottom: var(--spacing-md);
		max-width: 14ch;
	}

	.text-accent {
		color: #ce6b4a;
	}

	.hero-subtitle {
		font-size: 1.15rem;
		color: hsl(var(--muted-foreground));
		margin-bottom: var(--spacing-xl);
		max-width: 50ch;
		line-height: 1.7;
	}

	.hero-cta {
		display: flex;
		gap: var(--spacing-md);
		flex-wrap: wrap;
		margin-bottom: var(--spacing-xl);
	}

	.hero-newsletter {
		padding-top: var(--spacing-lg);
		border-top: 1px solid hsl(var(--border));
		max-width: 480px;
	}

	.hero-image img {
		width: 100%;
		max-height: 520px;
		object-fit: cover;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-lg);
	}

	/* Trust Bar */
	.trust-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-xl);
		padding: var(--spacing-xl) 0;
	}

	.trust-item {
		text-align: center;
	}

	.trust-icon {
		width: 3.5rem;
		height: 3.5rem;
		margin: 0 auto var(--spacing-md);
		color: hsl(var(--primary));
		background-color: hsl(var(--primary) / 0.08);
		border-radius: var(--radius-lg);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.trust-icon svg {
		width: 1.5rem;
		height: 1.5rem;
	}

	.trust-item h3 {
		font-family: var(--font-body);
		font-size: 1.05rem;
		font-weight: 600;
		margin-bottom: var(--spacing-xs);
	}

	.trust-item p {
		margin: 0;
		font-size: 0.9rem;
		color: hsl(var(--muted-foreground));
	}

	/* Section Header */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: var(--spacing-xl);
		flex-wrap: wrap;
		gap: var(--spacing-md);
	}

	.section-header h2 {
		margin: 0;
	}

	.section-lead {
		font-size: 1.05rem;
		max-width: 50ch;
		margin: var(--spacing-sm) auto 0;
	}

	.view-all {
		font-weight: 600;
		font-size: 0.95rem;
		white-space: nowrap;
	}

	/* Categories */
	.category-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-lg);
	}

	.category-card {
		background-color: hsl(var(--card));
		border: 1px solid hsl(var(--border));
		border-radius: var(--radius-card);
		padding: var(--spacing-xl);
		text-align: center;
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
	}

	.category-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
		border-color: hsl(var(--primary) / 0.25);
		text-decoration: none;
	}

	.category-icon {
		width: 3.5rem;
		height: 3.5rem;
		margin: 0 auto var(--spacing-md);
		color: hsl(var(--primary));
		background-color: hsl(var(--primary) / 0.08);
		border-radius: var(--radius-lg);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.category-icon svg {
		width: 1.5rem;
		height: 1.5rem;
	}

	.category-card h3 {
		font-family: var(--font-body);
		font-size: 1.15rem;
		font-weight: 600;
		margin-bottom: var(--spacing-sm);
	}

	.category-card p {
		margin: 0 0 var(--spacing-md);
		font-size: 0.95rem;
	}

	.category-link {
		font-size: 0.9rem;
		font-weight: 600;
		color: hsl(var(--primary));
	}

	/* Article Grid */
	.article-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-xl);
	}

	.article-card {
		background-color: hsl(var(--card));
		border-radius: var(--radius-card);
		overflow: hidden;
		box-shadow: var(--shadow-card);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
		border: 1px solid hsl(var(--border));
	}

	.article-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
	}

	.article-card-link {
		color: hsl(var(--foreground));
		display: block;
	}

	.article-card-link:hover {
		text-decoration: none;
	}

	.article-image {
		overflow: hidden;
	}

	.article-card img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.4s ease;
	}

	.article-card:hover img {
		transform: scale(1.03);
	}

	.article-card-content {
		padding: var(--spacing-lg);
	}

	.article-category {
		margin-bottom: var(--spacing-sm);
	}

	.article-card h3 {
		font-family: var(--font-body);
		font-size: 1.15rem;
		font-weight: 600;
		line-height: 1.4;
		margin-bottom: var(--spacing-sm);
	}

	.article-card p {
		font-size: 0.95rem;
		margin-bottom: var(--spacing-md);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.read-more {
		color: hsl(var(--primary));
		font-weight: 600;
		font-size: 0.9rem;
	}

	/* Research Process */
	.research-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-3xl);
		align-items: center;
	}

	.research-intro {
		font-size: 1.1rem;
		max-width: 45ch;
	}

	.research-image img {
		width: 100%;
		max-height: 450px;
		object-fit: cover;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-card);
	}

	.research-steps {
		padding-left: var(--spacing-lg);
		margin-bottom: var(--spacing-xl);
	}

	.research-steps li {
		font-size: 1rem;
		margin-bottom: var(--spacing-md);
		padding-left: var(--spacing-sm);
	}

	/* Newsletter CTA */
	.newsletter-cta h2 {
		margin-bottom: var(--spacing-sm);
	}

	.newsletter-cta p {
		margin-bottom: var(--spacing-xl);
		font-size: 1.05rem;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.category-grid,
		.article-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 992px) {
		.hero-grid,
		.research-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-2xl);
		}

		.hero-image {
			order: -1;
		}

		.trust-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.hero-content h1 {
			max-width: none;
		}

		.hero-cta {
			flex-direction: column;
		}

		.hero-cta .btn {
			width: 100%;
		}

		.category-grid,
		.article-grid,
		.trust-grid {
			grid-template-columns: 1fr;
		}

		.section-header {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
